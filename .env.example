# ─── Servidor ─────────────────────────────────────────────────
PORT=3000
ALLOWED_ORIGIN=https://sancar.com.br

# ─── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJh...   # service_role key (NUNCA exponha no frontend!)

# ─── Criptografia (AES-256-GCM) ────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=gere_uma_chave_de_64_chars_hex_aqui

# ─── E-mail (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.seuprovedor.com.br
SMTP_PORT=465
SMTP_USER=sistema@sancar.com.br
SMTP_PASS=sua_senha_aqui
NOTIFY_EMAIL=voce@sancar.com.br   # quem recebe o aviso de novo cliente


